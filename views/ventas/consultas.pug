extends ../layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Historial de Ventas - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Historial de Ventas

  .card-custom.h-100
    .card-body.p-0
      .p-3.border-bottom.d-flex.justify-content-between.align-items-center
        h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
          i.fa-solid.fa-clock-rotate-left.me-2
          | Registro Histórico
        .input-group(style="width: 300px;")
          input#searchVentas.form-control.form-control-sm(
            type="text", 
            placeholder="Buscar por cliente, ID, producto...",
            autocomplete="off"
          )
          button.btn.btn-outline-secondary.btn-sm
            i.fa-solid.fa-search
      .table-responsive
        table.table.table-custom.mb-0#tablaBusquedaVentas
          thead
            tr
              th ID
              th Cliente
              th Producto
              th Monto
              th Tipo
              th Fecha
              th Acciones
          tbody#ventasTableBody
            if ventas && ventas.length > 0
              each venta in ventas
                tr
                  td.text-muted ##{venta.id}
                  td.fw-bold= venta.cliente_nombre || 'Desconocido'
                  td= venta.producto_nombre || 'N/A'
                  td.fw-bold(style="color: var(--color-teal);") $#{venta.total}
                  td
                    if venta.tipo_comprobante === 'Factura'
                      span.badge.bg-info.text-dark
                        i.fa-solid.fa-file-invoice.me-1
                        | Factura
                    else
                      span.badge.bg-secondary
                        i.fa-solid.fa-receipt.me-1
                        | Ticket
                  td.small.text-muted= new Date(venta.fecha_emision).toLocaleString()
                  td
                    .d-flex.gap-2
                      a.btn.btn-sm.btn-outline-custom(href=`/ventas/ticket?id=${venta.id}`, title="Ver Ticket (POS)")
                        i.fa-solid.fa-receipt.me-1
                        | Ticket
                      if venta.tipo_comprobante === 'Factura'
                        a.btn.btn-sm.btn-outline-custom(href=`/ventas/factura-view?id=${venta.id}`, title="Ver Factura en PDF")
                          i.fa-solid.fa-file-pdf.me-1
                          | Factura
            else
              tr
                td(colspan="7").text-center.text-muted.p-4 No hay ventas registradas

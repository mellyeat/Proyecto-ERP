extends ../layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Ticket de Compra - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Visualizador de Ticket
    div
      button.btn.btn-outline-custom.me-2(type="button", onclick="window.print()")
        i.fa-solid.fa-print.me-2
        | Imprimir Comprobante
      a.btn.btn-secondary(href="/ventas/consultas")
        i.fa-solid.fa-arrow-left.me-2
        | Volver al Historial

  .row
    .col-md-4.mx-auto
      .card-custom.p-4(style="background-color: #fff; box-shadow: 0 0 10px rgba(0,0,0,0.1); width: 350px; margin: auto; font-family: monospace;")
        
        //- Encabezado Ticket
        .text-center.border-bottom.border-dark.border-2.pb-3.mb-3
          h4.fw-bold.mb-1 MINI ERP SYSTEM
          p.small.mb-0 SUCURSAL CENTRO
          p.small.mb-0 Tel: (123) 456-7890
          p.small.mb-0 Ticket: #008542
          p.small.mb-0 Fecha: 30/03/2026 14:35
        
        //- Datos del Cliente (Opcional en tickets, pero si es necesario)
        .mb-3
          p.small.mb-0 <strong>Cliente:</strong> Empresa ACME
          p.small.mb-0 <strong>Cajero:</strong> Admin
        
        //- Detalles de Venta
        .mb-3
          table.table.table-sm.table-borderless.mb-0
            thead.border-bottom.border-dark
              tr.small.fw-bold
                th(style="width: 15%") Cant
                th(style="width: 60%") Artículo
                th.text-end(style="width: 25%") Importe
            tbody.small
              tr
                td.text-center 2
                td Monitor 24" 144Hz
                td.text-end $280.00
              tr
                td.text-center 1
                td Teclado RGB
                td.text-end $65.00
              tr
                td.text-center 3
                td Mouse WiFi
                td.text-end $75.00

        //- Totales
        .border-top.border-dark.border-2.pt-2.mt-2
          .d-flex.justify-content-between.small.mb-1
            span Subtotal:
            span $420.00
          .d-flex.justify-content-between.small.mb-1
            span IVA:
            span $67.20
          .d-flex.justify-content-between.fw-bold.fs-5.mt-2
            span TOTAL:
            span $487.20

        //- Pie de Ticket
        .text-center.mt-4.pt-3.border-top.border-dark.border-dashed
          p.small.mb-1 ¡GRACIAS POR SU COMPRA!
          p.small.mb-0 Vuelva pronto a Mini ERP
          p.small.text-muted.mt-2.mb-0 * Conservar ticket para cambios *

extends ../layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Ticket de Compra - ERP'

block content
  //- Estilos específicos para visualización y PDF
  style.
    .ticket-container {
      background-color: #ffffff !important;
      width: 350px;
      margin: 20px auto;
      padding: 20px;
      font-family: 'Courier New', Courier, monospace;
      color: #000;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      border: 1px solid #eee;
    }
    
    /* Ajustes para que las tablas se vean bien en el PDF */
    .ticket-container table {
      width: 100%;
      border-collapse: collapse;
    }
    
    @media print {
      .no-print { display: none !important; }
      body { background: none; }
      .ticket-container { 
        box-shadow: none; 
        border: none; 
        margin: 0; 
        width: 100%;
      }
    }

  //- Botones de acción (No se verán en el PDF)
  .d-flex.justify-content-between.align-items-center.mb-4.no-print
    h2.fw-bold(style="color: var(--color-dark-teal);") Visualizador de Ticket
    div
      button.btn.btn-danger.me-2(type="button", onclick="descargarPDF()")
        i.fa-solid.fa-file-pdf.me-2
        | Descargar PDF
      button.btn.btn-outline-primary.me-2(type="button", onclick="window.print()")
        i.fa-solid.fa-print.me-2
        | Imprimir
      a.btn.btn-secondary(href="/ventas/consultas")
        i.fa-solid.fa-arrow-left.me-2
        | Volver

  .row
    .col-12
      //- Este es el div que capturará el PDF
      #printableArea.ticket-container
        //- Encabezado
        .text-center.border-bottom.border-dark.pb-3.mb-3
          h4.fw-bold.mb-1 MINI ERP SYSTEM
          p.small.mb-0 SUCURSAL CENTRO
          p.small.mb-0 Tel: (123) 456-7890
          p.small.mb-0 Ticket: ##{venta.id}
          p.small.mb-0 Fecha: #{new Date(venta.fecha_emision).toLocaleString('es-MX')}

        //- Información de Venta
        .mb-3
          p.small.mb-0
            strong Cliente: 
            | #{venta.cliente_nombre || 'Público General'}
          p.small.mb-0
            strong Cajero: 
            | #{venta.cajero_nombre || 'Admin'}

        //- Tabla de Productos
        .mb-3
          table.table.table-sm.table-borderless
            thead.border-bottom.border-dark
              tr.small.fw-bold
                th(style="width:15%") Cant
                th(style="width:55%") Artículo
                th.text-end(style="width:30%") Importe
            tbody.small
              each detalle in detalles
                tr
                  td.text-center= detalle.cantidad
                  td= detalle.producto_nombre
                  td.text-end $#{parseFloat(detalle.importe_linea).toFixed(2)}

        //- Totales
        .border-top.border-dark.border-2.pt-2.mt-2
          .d-flex.justify-content-between.small.mb-1
            span Subtotal:
            span $#{parseFloat(venta.subtotal).toFixed(2)}
          .d-flex.justify-content-between.small.mb-1
            span IVA (16%):
            span $#{parseFloat(venta.iva).toFixed(2)}
          .d-flex.justify-content-between.fw-bold.fs-5.mt-2
            span TOTAL:
            span $#{parseFloat(venta.total).toFixed(2)}

        //- Pie de página
        .text-center.mt-4.pt-3.border-top.border-dark
          p.small.mb-1 ¡GRACIAS POR SU COMPRA!
          p.small.mb-0 Vuelva pronto
          p.small.text-muted.mt-2.mb-0 * Conservar ticket para cambios *

block scripts
  script(src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js")
  script.
    function descargarPDF() {
      const element = document.getElementById('printableArea');
      
      const opt = {
        margin:       [10, 10, 10, 10],
        filename:     'Factura_#{folio}.pdf',
        image:        { type: 'jpeg', quality: 1 },
        html2canvas:  { 
          scale: 3, 
          useCORS: true, 
          backgroundColor: '#ffffff',
          scrollY: 0,
          // ESTA ES LA MAGIA: Forzamos a que todo sea legible en la copia del PDF
          onclone: (doc) => {
            const pdfView = doc.getElementById('printableArea');
            // Ponemos todo el texto en negro puro para que no se vea pálido
            const allElements = pdfView.getElementsByTagName('*');
            for (let el of allElements) {
              // Si no es un badge, forzamos negro
              if (!el.classList.contains('badge')) {
                el.style.color = '#000000';
                el.style.opacity = '1';
              }
            }
            // Forzamos que las líneas de la tabla sean negras y visibles
            const tables = pdfView.getElementsByTagName('table');
            for (let table of tables) {
              table.style.borderColor = '#000000';
            }
          }
        },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().set(opt).from(element).save();
    }
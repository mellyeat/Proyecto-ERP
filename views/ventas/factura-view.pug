extends ../layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Factura - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Visualizador de Factura
    div
      button.btn.btn-outline-custom.me-2(type="button")
        i.fa-solid.fa-envelope.me-2
        | Enviar por Correo
      button.btn.btn-primary-custom(type="button")
        i.fa-solid.fa-print.me-2
        | Imprimir PDF

  .row
    .col-md-8.mx-auto
      .card-custom.p-5(style="background-color: #fff; box-shadow: 0 0 20px rgba(0,0,0,0.05);")
        
        //- Encabezado Factura
        .row.border-bottom.pb-4.mb-4
          .col-md-6
            h3.fw-bold(style="color: var(--color-dark-teal);") Mini ERP System
            p.text-muted.small.mb-0 123 Calle Falsa, Ciudad
            p.text-muted.small.mb-0 RFC: XAXX010101000
            p.text-muted.small.mb-0 contacto@minierp.com
          .col-md-6.text-end
            h2.fw-light.text-uppercase FACTURA
            h6.fw-bold.text-muted #INV-2026-0085
            p.text-muted.small.mb-0 Fecha: 30 de Marzo, 2026
        
        //- Datos del Cliente
        .row.mb-5
          .col-md-6
            h6.fw-bold.text-muted FACTURADO A:
            h5.fw-bold Empresa ACME S.A.
            p.text-muted.small.mb-0 Av. Principal 456, Corporativo VIP
            p.text-muted.small.mb-0 acme.contacto@empresa.com
        
        //- Detalles de Venta
        .table-responsive.mb-4
          table.table.table-bordered
            thead.bg-light
              tr
                th.text-center Cantidad
                th Descripción
                th.text-end P. Unitario
                th.text-end Importe
            tbody
              tr
                td.text-center 2
                td Monitor 24" 144Hz
                td.text-end $140.00
                td.text-end $280.00
              tr
                td.text-center 1
                td Teclado Mecánico RGB
                td.text-end $65.00
                td.text-end $65.00
              tr
                td.text-center 3
                td Mouse Inalámbrico
                td.text-end $25.00
                td.text-end $75.00

        //- Totales
        .row.justify-content-end
          .col-md-5
            .d-flex.justify-content-between.mb-2
              span.fw-bold.text-muted Subtotal:
              span $420.00
            .d-flex.justify-content-between.mb-2
              span.fw-bold.text-muted IVA (16%):
              span $67.20
            .d-flex.justify-content-between.border-top.pt-2.mt-2
              span.fw-bold.fs-5(style="color: var(--color-dark-teal);") Total:
              span.fw-bold.fs-5(style="color: var(--color-teal);") $487.20

        //- Pie de Factura
        .text-center.mt-5.pt-4.border-top
          p.text-muted.small.mb-0 Gracias por su preferencia.
          p.text-muted.small.mb-0 Este documento es una representación impresa de un CFDI.

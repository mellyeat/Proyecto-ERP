extends ../layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Factura - ERP'
  - var folio = String(venta.id).padStart(4, '0')

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Visualizador de Factura
    div
      button.btn.btn-outline-custom.me-2(type="button")
        i.fa-solid.fa-envelope.me-2
        | Enviar por Correo
      button.btn.btn-primary-custom.me-2(type="button", onclick=`descargarPDF('Factura_${folio}.pdf')`)
        i.fa-solid.fa-file-pdf.me-2
        | Descargar PDF
      a.btn.btn-secondary(href="/ventas/consultas")
        i.fa-solid.fa-arrow-left.me-2
        | Volver al Historial

  .row
    .col-md-9.mx-auto
      .a4-container#printableArea
        .company-header.d-flex.justify-content-between.align-items-center
          div
            .brand-title Mi Empresa ERP
            p.text-muted.mb-0 Soluciones Integrales
            p.text-muted.small.mb-0 RFC: XAXX010101000
            p.text-muted.small.mb-0 contacto@minierp.com
          div.text-end.invoice-details
            h3.fw-bold FACTURA
            p Folio: 
              strong #INV-2026-#{folio}
            p Fecha: #{new Date(venta.fecha_emision).toLocaleDateString('es-MX')}
            .mt-2
              - var estadoColor = venta.estado === 'Pagada' ? 'success' : 'warning'
              span(class=`badge bg-${estadoColor}`)= venta.estado

        //- Datos del cliente
        .row.mb-5
          .col-md-7
            h6.fw-bold.text-muted FACTURADO A:
            h5.fw-bold= venta.cliente_nombre || 'Público General'
            if venta.cliente_razon_social
              p.text-muted.small.mb-0= venta.cliente_razon_social
            if venta.cliente_rfc
              p.text-muted.small.mb-0 RFC: #{venta.cliente_rfc}
            if venta.cliente_direccion
              p.text-muted.small.mb-0= venta.cliente_direccion
            if venta.cliente_cp
              p.text-muted.small.mb-0 C.P.: #{venta.cliente_cp}
            if venta.cliente_email
              p.text-muted.small.mb-0= venta.cliente_email
            if venta.cliente_regimen
              p.text-muted.small.mb-0 Régimen: #{venta.cliente_regimen}
          .col-md-5.text-end
            if venta.folio_fiscal
              p.text-muted.small.mb-1
                strong UUID CFDI:
              p.small.text-break= venta.folio_fiscal

        //- Tabla de productos
        .table-responsive.mb-4
          table.table.table-bordered
            thead.bg-light
              tr
                th.text-center Cantidad
                th Descripción
                th.text-end P. Unitario
                th.text-end Importe
            tbody
              each detalle in detalles
                tr
                  td.text-center= detalle.cantidad
                  td= detalle.producto_nombre
                  td.text-end $#{parseFloat(detalle.precio_unitario).toFixed(2)}
                  td.text-end $#{parseFloat(detalle.importe_linea).toFixed(2)}

        //- Totales
        .row.justify-content-end
          .col-md-5
            .d-flex.justify-content-between.mb-2
              span.fw-bold.text-muted Subtotal:
              span $#{parseFloat(venta.subtotal).toFixed(2)}
            .d-flex.justify-content-between.mb-2
              span.fw-bold.text-muted IVA (16%):
              span $#{parseFloat(venta.iva).toFixed(2)}
            .d-flex.justify-content-between.border-top.pt-2.mt-2
              span.fw-bold.fs-5(style="color: var(--color-dark-teal);") Total:
              span.fw-bold.fs-5(style="color: var(--color-teal);") $#{parseFloat(venta.total).toFixed(2)}

        //- Pie
        .text-center.mt-5.pt-4.border-top
          p.text-muted.small.mb-0 Gracias por su preferencia.
          p.text-muted.small.mb-0 Este documento es una representación impresa de un CFDI.
          if venta.cajero_nombre
            p.text-muted.small.mt-2.mb-0 Atendido por: #{venta.cajero_nombre}

block scripts
  script(src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js")
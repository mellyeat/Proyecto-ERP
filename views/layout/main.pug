block variables

doctype html
html(lang="es")
  head
    title #{title ? title : 'ERP'}
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    link(rel="stylesheet", href="/css/style.css")

  body
    .container-fluid.p-0
      .row.g-0
        // Sidebar
        .col-md-2.sidebar.d-flex.flex-column
          .sidebar-heading
            i.fa-solid.fa-chart-pie.me-2
            | Mini ERP
          ul.nav.flex-column.mt-3.flex-grow-1
            li.nav-item
              a.nav-link.sidebar-link(href="/dashboard", class=(activePage === 'dashboard' ? 'active' : ''))
                i.fa-solid.fa-gauge-high.me-2
                | Dashboard
            li.nav-item
              a.nav-link.sidebar-link(href="/empleados", class=(activePage === 'empleados' ? 'active' : ''))
                i.fa-solid.fa-users.me-2
                | Empleados
            li.nav-item
              a.nav-link.sidebar-link(href="/productos", class=(activePage === 'productos' ? 'active' : ''))
                i.fa-solid.fa-box-open.me-2
                | Productos
            li.nav-item
              a.nav-link.sidebar-link(href="/ventas", class=(activePage === 'ventas' ? 'active' : ''))
                i.fa-solid.fa-money-bill-wave.me-2
                | Ventas
                
          .mt-auto.p-3
            .text-center.text-white-50.small
              | &copy; 2026 ERP System

        // Main Content Area
        .col-md-10.d-flex.flex-column.min-vh-100
          // Navbar Top
          nav.navbar.navbar-expand-lg.top-navbar.d-flex.justify-content-between.align-items-center
            span.navbar-brand.fs-5.text-muted Hola, Bienvenido
            div
              a.btn.btn-outline-custom.btn-sm(href="/") 
                i.fa-solid.fa-arrow-right-from-bracket.me-2
                | Cerrar sesión

          // Page Content
          .p-4.flex-grow-1
            block content
          
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    block scripts

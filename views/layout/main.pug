block variables

doctype html
html
  head
    title #{title ? title : 'ERP'}
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")

  body.bg-light

    nav.navbar.navbar-dark.bg-dark.shadow-sm
      .container-fluid
        span.navbar-brand.fw-bold Mini ERP
        a.btn.btn-outline-light(href="/") Cerrar sesión

    .container-fluid
      .row

        .col-md-2.bg-white.shadow-sm.min-vh-100.p-3
          h6.text-muted MENÚ
          ul.nav.flex-column.mt-3
            li.nav-item
              a.nav-link(href="/dashboard", class=(activePage === 'dashboard' ? 'active' : ''))
                i.fa-solid.fa-gauge-high.me-2
                | Dashboard
            li.nav-item
              a.nav-link(href="/empleados", class=(activePage === 'empleados' ? 'active' : ''))
                i.fa-solid.fa-users.me-2
                | Empleados
            li.nav-item
              a.nav-link(href="/productos", class=(activePage === 'productos' ? 'active' : ''))
                i.fa-solid.fa-box-open.me-2
                | Productos
            li.nav-item
              a.nav-link(href="/ventas", class=(activePage === 'ventas' ? 'active' : ''))
                i.fa-solid.fa-money-bill-wave.me-2
                | Ventas

        .col-md-10.p-4
          block content
          
    block scripts

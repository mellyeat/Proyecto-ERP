block variables

doctype html
html(lang="es")
  head
    title #{title ? title : 'ERP'}
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")

    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    link(rel="stylesheet", href="/css/style.css")
    link(rel="stylesheet", href="/css/views.css")

  body
    // Mobile Sidebar Overlay
    #sidebarOverlay.sidebar-overlay

    .container-fluid.p-0
      .row.g-0

        // ================= SIDEBAR =================
        .col-md-2.sidebar.d-flex.flex-column#mobileSidebar
          .sidebar-heading
            i.fa-solid.fa-chart-pie.me-2
            | Mini ERP

          ul.nav.flex-column.mt-3.flex-grow-1

            li.nav-item
              a.nav-link.sidebar-link(
                href="/dashboard", 
                class=(activePage === 'dashboard' ? 'active' : '')
              )
                i.fa-solid.fa-gauge-high.me-2
                | Dashboard

            if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'RH')
              li.nav-item
                a.nav-link.sidebar-link(
                  data-bs-toggle="collapse",
                  href="#empleadosMenu",
                  role="button",
                  aria-expanded=(activePage === 'empleados' ? 'true' : 'false'),
                  aria-controls="empleadosMenu",
                  class=(activePage === 'empleados' ? 'active' : '')
                )
                  i.fa-solid.fa-users.me-2
                  | Empleados
                  i.fa-solid.fa-chevron-down.float-end.mt-1(style="font-size: 0.8rem;")

                .collapse(id="empleadosMenu", class=(activePage === 'empleados' ? 'show' : ''))
                  ul.nav.flex-column.ms-3.mt-2
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/empleados")
                        i.fa-solid.fa-chart-simple.me-2
                        | Resumen
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/empleados/altas")
                        i.fa-solid.fa-user-plus.me-2
                        | Nuevo Empleado
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/empleados/consultas")
                        i.fa-solid.fa-id-card.me-2
                        | Directorio

            if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'COMPRAS')
              li.nav-item
                a.nav-link.sidebar-link(
                  data-bs-toggle="collapse",
                  href="#productosMenu",
                  role="button",
                  aria-expanded=(activePage === 'productos' ? 'true' : 'false'),
                  aria-controls="productosMenu",
                  class=(activePage === 'productos' ? 'active' : '')
                )
                  i.fa-solid.fa-box-open.me-2
                  | Productos
                  i.fa-solid.fa-chevron-down.float-end.mt-1(style="font-size: 0.8rem;")
                
                .collapse(id="productosMenu", class=(activePage === 'productos' ? 'show' : ''))
                  ul.nav.flex-column.ms-3.mt-2
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/productos") 
                        i.fa-solid.fa-chart-simple.me-2
                        | Resumen
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/productos/altas") 
                        i.fa-solid.fa-plus-circle.me-2
                        | Nuevo Producto
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/productos/consultas")
                        i.fa-solid.fa-list.me-2
                        | Inventario
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/productos/proveedores")
                        i.fa-solid.fa-truck-fast.me-2
                        | Proveedores

            if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'VENTAS')
              li.nav-item
                a.nav-link.sidebar-link(
                  data-bs-toggle="collapse",
                  href="#ventasMenu",
                  role="button",
                  aria-expanded=(activePage === 'ventas' ? 'true' : 'false'),
                  aria-controls="ventasMenu",
                  class=(activePage === 'ventas' ? 'active' : '')
                )
                  i.fa-solid.fa-money-bill-wave.me-2
                  | Ventas
                  i.fa-solid.fa-chevron-down.float-end.mt-1(style="font-size: 0.8rem;")
                
                .collapse(id="ventasMenu", class=(activePage === 'ventas' ? 'show' : ''))
                  ul.nav.flex-column.ms-3.mt-2
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/ventas") 
                        i.fa-solid.fa-chart-simple.me-2
                        | Resumen
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/ventas/altas") 
                        i.fa-solid.fa-plus-circle.me-2
                        | Nueva Venta
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/ventas/consultas")
                        i.fa-solid.fa-list.me-2
                        | Historial
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/ventas/facturas")
                        i.fa-solid.fa-file-invoice.me-2
                        | Facturas

            if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'VENTAS')
              li.nav-item
                a.nav-link.sidebar-link(
                  data-bs-toggle="collapse",
                  href="#clientesMenu",
                  role="button",
                  aria-expanded=(activePage === 'clientes' ? 'true' : 'false'),
                  aria-controls="clientesMenu",
                  class=(activePage === 'clientes' ? 'active' : '')
                )
                  i.fa-solid.fa-users.me-2
                  | Clientes
                  i.fa-solid.fa-chevron-down.float-end.mt-1(style="font-size: 0.8rem;")
                
                .collapse(id="clientesMenu", class=(activePage === 'clientes' ? 'show' : ''))
                  ul.nav.flex-column.ms-3.mt-2
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/clientes") 
                        i.fa-solid.fa-chart-simple.me-2
                        | Resumen
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/clientes/altas") 
                        i.fa-solid.fa-user-plus.me-2
                        | Nuevo Cliente
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/clientes/consultas")
                        i.fa-solid.fa-address-book.me-2
                        | Directorio

            if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'VENTAS')
              li.nav-item
                a.nav-link.sidebar-link(
                  data-bs-toggle="collapse",
                  href="#cotizacionesMenu",
                  role="button",
                  aria-expanded=(activePage === 'cotizaciones' ? 'true' : 'false'),
                  aria-controls="cotizacionesMenu",
                  class=(activePage === 'cotizaciones' ? 'active' : '')
                )
                  i.fa-solid.fa-file-signature.me-2
                  | Cotizaciones
                  i.fa-solid.fa-chevron-down.float-end.mt-1(style="font-size: 0.8rem;")
                
                .collapse(id="cotizacionesMenu", class=(activePage === 'cotizaciones' ? 'show' : ''))
                  ul.nav.flex-column.ms-3.mt-2
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/cotizaciones/altas") 
                        i.fa-solid.fa-plus-circle.me-2
                        | Nueva Cotización
                    li.nav-item
                      a.nav-link.sidebar-link.small.py-1(href="/cotizaciones/consultas")
                        i.fa-solid.fa-list.me-2
                        | Historial


          .mt-auto.p-3
            .text-center.text-white-50.small
              | © 2026 ERP System

        .col-md-10.d-flex.flex-column.min-vh-100

          nav.navbar.navbar-expand-lg.top-navbar.d-flex.justify-content-between.align-items-center
            .d-flex.align-items-center
              button#sidebarToggle.btn.btn-link.d-md-none.me-2(style="color: var(--color-dark-teal); font-size: 1.5rem;")
                i.fa-solid.fa-bars
              span.navbar-brand.fs-5.text-muted Hola, Bienvenido

            .d-flex.align-items-center.gap-3
              //- Notification Bell
              .position-relative#notifBellWrapper
                button#notifBell.btn.btn-link.position-relative.p-1(
                  type="button",
                  aria-label="Notificaciones",
                  style="color: var(--color-dark-teal); font-size: 1.25rem; text-decoration: none;"
                )
                  i.fa-solid.fa-bell
                  span#notifBadge.notif-badge.d-none 0
                
                //- Dropdown Panel
                .notif-panel#notifPanel
                  .notif-header
                    span.fw-bold
                      i.fa-solid.fa-triangle-exclamation.me-2
                      | Stock Bajo
                    span#notifCount.notif-count 0 alertas
                  #notifList.notif-list
                    .notif-empty
                      i.fa-solid.fa-check-circle.me-2.text-success
                      | Todo en orden — no hay alertas
                  .notif-footer
                    a(href="/productos/consultas")
                      i.fa-solid.fa-boxes-stacked.me-1
                      | Ver inventario completo

              a.btn.btn-outline-custom.btn-sm(href="/logout") 
                i.fa-solid.fa-arrow-right-from-bracket.me-2
                | Cerrar sesión

          .p-4.flex-grow-1
            block content

    // ================= BOTTOM NAV (MOBILE) =================
    nav.bottom-nav.d-md-none
      a.bottom-nav-item(href="/dashboard", class=(activePage === 'dashboard' ? 'active' : ''))
        i.fa-solid.fa-gauge-high
        span Inicio
      if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'VENTAS')
        a.bottom-nav-item(href="/ventas", class=(activePage === 'ventas' ? 'active' : ''))
          i.fa-solid.fa-money-bill-wave
          span Ventas
      if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'COMPRAS')
        a.bottom-nav-item(href="/productos/consultas", class=(activePage === 'productos' ? 'active' : ''))
          i.fa-solid.fa-box-open
          span Stock
      if usuario && (usuario.rol === 'SUPER ADMIN' || usuario.rol === 'admin' || usuario.rol === 'Admin' || usuario.rol === 'VENTAS')
        a.bottom-nav-item(href="/clientes/consultas", class=(activePage === 'clientes' ? 'active' : ''))
          i.fa-solid.fa-users
          span Clientes

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    script(src="/js/views.js")
    block scripts
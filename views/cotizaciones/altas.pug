extends ../layout/main.pug

block variables
  - var activePage = 'cotizaciones'
  - var title = 'Nueva Cotización - ERP'

block content

  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Nueva Cotización

  .row
    .col-md-6.mx-auto
      .card-custom
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
              i.fa-solid.fa-file-signature.me-2
              | Detalles de la Cotización
          .p-4
            form(action="/cotizaciones/add", method="POST")
              .mb-3
                label.form-label.text-muted.small Nombre del Cliente
                select.form-select.bg-light(name="cliente_id", required)
                  option(value="" disabled selected) Seleccionar cliente...
                  if clientes && clientes.length > 0
                    each cliente in clientes
                      option(value=cliente.id)= cliente.nombre_comercial

              .mb-3
                label.form-label.text-muted.small Seleccionar Producto
                select.form-select.bg-light(name="producto_id", id="producto", required)
                  option(value="" disabled selected) Elige un producto
                  if productos && productos.length > 0
                    each prod in productos
                      option(
                        value=prod.id
                        data-precio=prod.precio
                      ) #{prod.nombre} - $#{prod.precio}
                  else
                    option(value="" disabled) No hay productos disponibles

              .row.mb-3
                .col-6
                  label.form-label.text-muted.small Cantidad
                  input.form-control.bg-light(
                    type="number",
                    name="cantidad",
                    id="cantidad",
                    min="1",
                    value="1",
                    required
                  )
                .col-6
                  label.form-label.text-muted.small Total Estimado ($)
                  input.form-control.bg-white.fw-bold(
                    type="number",
                    step="0.01",
                    name="monto",
                    id="monto",
                    required,
                    readonly,
                    style="color: var(--color-teal);"
                  )

              .mb-3
                label.form-label.text-muted.small Vigencia (Días)
                input.form-control.bg-light(
                  type="number",
                  name="vigencia_dias",
                  min="1",
                  value="15",
                  required
                )

              button.btn.btn-primary-custom.w-100(type="submit") Guardar Cotización

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const selectProducto = document.getElementById('producto');
      const inputMonto = document.getElementById('monto');
      const inputCantidad = document.getElementById('cantidad');

      function actualizarTotal() {
        if(!selectProducto || !inputMonto || !inputCantidad) return;
        const selectedOption = selectProducto.options[selectProducto.selectedIndex];
        const precio = selectedOption ? selectedOption.dataset.precio : null;
        const cantidad = inputCantidad.value;

        if (precio && cantidad) {
          inputMonto.value = (precio * cantidad).toFixed(2);
        } else {
          inputMonto.value = '';
        }
      }

      if(selectProducto) selectProducto.addEventListener('change', actualizarTotal);
      if(inputCantidad) inputCantidad.addEventListener('input', actualizarTotal);

      // Validación del formulario
      const form = document.querySelector('form');
      form.addEventListener('submit', function(e) {
        const clienteId = form.querySelector('[name="cliente_id"]');
        const productoId = form.querySelector('[name="producto_id"]');
        const cantidad = form.querySelector('[name="cantidad"]');
        const vigencia = form.querySelector('[name="vigencia_dias"]');
        let errors = [];

        if (!clienteId.value) errors.push('Debes seleccionar un cliente');
        if (!productoId.value) errors.push('Debes seleccionar un producto');
        if (cantidad.value === '' || Number(cantidad.value) < 1 || !Number.isInteger(Number(cantidad.value))) {
          errors.push('La cantidad debe ser un número entero mayor o igual a 1');
        }
        if (vigencia.value === '' || Number(vigencia.value) < 1 || !Number.isInteger(Number(vigencia.value))) {
          errors.push('La vigencia debe ser al menos 1 día');
        }

        if (errors.length > 0) {
          e.preventDefault();
          let existingAlert = document.querySelector('.validation-alert');
          if (existingAlert) existingAlert.remove();
          const alertDiv = document.createElement('div');
          alertDiv.className = 'validation-alert alert alert-danger';
          alertDiv.innerHTML = '<strong>Errores:</strong><ul>' + errors.map(er => '<li>' + er + '</li>').join('') + '</ul>';
          form.parentElement.prepend(alertDiv);
          window.scrollTo({top: 0, behavior: 'smooth'});
        }
      });
    });

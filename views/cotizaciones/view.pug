extends ../layout/main.pug

block variables
  - var activePage = 'cotizaciones'
  - var title = 'Cotización - ERP'

block content
  style.
    .a4-container {
      background: #fff;
      margin: 0 auto;
      padding: 40px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      border-radius: 8px;
    }
    .company-header {
      border-bottom: 2px solid #000;
      padding-bottom: 15px;
      margin-bottom: 30px;
    }
    .brand-title {
      font-size: 2rem;
      font-weight: bold;
      color: #2c3e50;
    }
    .invoice-details p {
      margin: 0;
      font-size: 0.9rem;
    }
    @media print {
      body * {
        visibility: hidden;
      }
      #printableArea, #printableArea * {
        visibility: visible;
      }
      #printableArea {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        box-shadow: none;
        padding: 0;
      }
      .a4-container { margin: 0; }
    }

  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Visualizador de Cotización
    div
      button.btn.btn-primary-custom.me-2(type="button", onclick="descargarPDF()")
        i.fa-solid.fa-file-pdf.me-2
        | Descargar PDF
      a.btn.btn-secondary(href="/cotizaciones/consultas")
        i.fa-solid.fa-arrow-left.me-2
        | Volver al Historial

  .row
    .col-md-9.mx-auto
      .a4-container#printableArea
        .company-header.d-flex.justify-content-between.align-items-center
          div
            .brand-title Mi Empresa ERP
            p.text-muted.mb-0 Soluciones Integrales
          div.text-end.invoice-details
            h3.fw-bold COTIZACIÓN
            p Folio: 
              strong C-#{String(cotizacion.id).padStart(5, '0')}
            p Fecha: #{new Date(cotizacion.fecha_emision).toLocaleDateString('es-MX')}
            p Vigencia: #{cotizacion.vigencia_dias} días

        .row.mb-4
          .col-sm-6
            h6.fw-bold Preparado para:
            p.mb-1 
              strong #{cotizacion.cliente_nombre}
            p.mb-1 #{cotizacion.cliente_razon_social || ''}
            p.mb-1 #{cotizacion.cliente_rfc ? 'RFC: ' + cotizacion.cliente_rfc : ''}
            p.mb-1 #{cotizacion.cliente_direccion || ''}
            p.mb-1 #{cotizacion.cliente_email || ''}
          .col-sm-6.text-end
            h6.fw-bold Vendedor:
            p.mb-1 #{cotizacion.cajero_nombre}

        table.table.table-bordered.mt-4
          thead.table-light
            tr
              th.text-center Cant.
              th Descripción
              th.text-end P. Unitario
              th.text-end Importe
          tbody
            if detalles && detalles.length > 0
              each item in detalles
                tr
                  td.text-center #{item.cantidad}
                  td #{item.producto_nombre}
                  td.text-end $#{item.precio_unitario}
                  td.text-end $#{item.importe_linea}
            else
              tr
                td(colspan="4").text-center Sin detalles.

        .row.mt-4
          .col-sm-7
            p.text-muted.small 
              strong Condiciones comerciales:
              br
              | Precios en moneda nacional (MXN).
              br
              | Esta cotización tiene una vigencia de #{cotizacion.vigencia_dias} días naturales tras su emisión.
              br
              | Cualquier discrepancia o modificación requerirá de una nueva cotización.
          .col-sm-5
            table.table.table-sm.table-borderless.text-end
              tr
                td Subtotal:
                td.fw-bold $#{cotizacion.subtotal}
              tr
                td IVA (16%):
                td.fw-bold $#{cotizacion.iva}
              tr.border-top
                td.fs-5.fw-bold TOTAL:
                td.fs-5.fw-bold.text-primary $#{cotizacion.total}

        .mt-5.text-center
          br
          br
          p.mb-0 _________________________________________
          p.small Firma de Aceptación

block scripts
  script(src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js")
  script.
    function descargarPDF() {
      const element = document.getElementById('printableArea');
      const opt = {
        margin:       [10, 10, 10, 10],
        filename:     'Cotizacion.pdf',
        image:        { type: 'jpeg', quality: 0.98 },
        html2canvas:  { scale: 2 },
        jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };
      html2pdf().set(opt).from(element).save();
    }

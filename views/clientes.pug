extends layout/main.pug

block variables
  - var activePage = 'clientes'
  - var title = 'Resumen de Clientes - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Panel de Clientes

  //- Tarjetas de Métricas de Clientes
  .row.g-4.mb-4
    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Clientes Totales
            h3.fw-bold.mb-0 #{totalClientes || 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(9, 99, 126, 0.1);")
            i.fa-solid.fa-users.fs-3(style="color: var(--color-dark-teal);")
          
    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Con Datos Fiscales
            h3.fw-bold.mb-0 #{conFactura || 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(255, 193, 7, 0.1);")
            i.fa-solid.fa-file-invoice.fs-3.text-warning
          
    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Sin Factura
            - var sinFactura = (totalClientes || 0) - (conFactura || 0)
            h3.fw-bold.mb-0 #{sinFactura}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(13, 202, 240, 0.1);")
            i.fa-solid.fa-user-tag.fs-3.text-info

  //- Top Clientes
  .row.g-4
    .col-md-12
      .card-custom.h-100
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-crown.me-2
              | Clientes Top (Por Monto de Ventas)
          .table-responsive
            table.table.table-custom.mb-0.align-middle
              thead
                tr
                  th #
                  th Cliente
                  th Total Comprado
                  th Nivel
              tbody
                if topClientes && topClientes.length > 0
                  each cli, i in topClientes
                    tr
                      td.text-muted #{i + 1}
                      td.fw-bold= cli.nombre_comercial
                      td.fw-bold(style="color: var(--color-teal);") $#{parseFloat(cli.monto_total).toLocaleString('es-MX')}
                      td
                        if i === 0
                          span.badge.bg-success Oro
                        else if i === 1
                          span.badge.bg-primary Plata
                        else if i === 2
                          span.badge.bg-warning.text-dark Bronce
                        else
                          span.badge.bg-secondary Regular
                else
                  tr
                    td(colspan="4").text-center.text-muted.p-4 No hay clientes con ventas registradas

extends ../layout/main.pug

block variables
  - var activePage = 'productos'
  - var title = 'Directorio de Proveedores - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Control de Proveedores
    a.btn.btn-primary-custom(href="/productos/proveedor-altas")
      i.fa-solid.fa-plus.me-2
      | Añadir Proveedor

  .row.mb-4
    .col-md-12
      .card-custom
        .card-body.p-0
          .p-3.border-bottom.d-flex.justify-content-between.align-items-center
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-truck-fast.me-2
              | Proveedores Registrados
            .input-group(style="width: 250px;")
              input.form-control.form-control-sm(type="text", placeholder="Buscar proveedor...")
              button.btn.btn-outline-secondary.btn-sm
                i.fa-solid.fa-search
                
          .table-responsive
            table.table.table-custom.mb-0.align-middle
              thead
                tr
                  th ID
                  th Proveedor
                  th Contacto
                  th Artículos Surtidos
                  th Estado
                  th Acciones
              tbody
                if proveedores && proveedores.length > 0
                  each prov in proveedores
                    tr
                      td.text-muted #PRV-#{prov.id}
                      td
                        .fw-bold= prov.razon_social
                        .small.text-muted= prov.categoria
                      td
                        .small
                          i.fa-solid.fa-phone.me-1.text-muted
                          | #{prov.telefono}
                        .small
                          i.fa-solid.fa-envelope.me-1.text-muted
                          | #{prov.email}
                      td.text-center
                        span.badge.bg-light.text-dark.border 0 productos
                      td
                        span.badge.bg-success Activo
                      td
                        .d-flex.gap-2
                          button.btn.btn-sm.btn-warning(title="Editar Proveedor", disabled)
                            i.fa-solid.fa-pencil
                          button.btn.btn-sm.btn-outline-custom(title="Ver Productos Surtidos", disabled)
                            i.fa-solid.fa-box-open
                else
                  tr
                    td(colspan="6").text-center.text-muted No hay proveedores registrados

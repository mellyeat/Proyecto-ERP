extends ../layout/main.pug

block variables
  - var activePage = 'productos'
  - var title = 'Añadir Proveedor - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Registrar Proveedor
    a.btn.btn-outline-secondary(href="/productos/proveedores")
      i.fa-solid.fa-arrow-left.me-2
      | Volver al Directorio

  form(action="/productos/proveedor-add", method="POST")
    .row.g-4
      //- SECCIÓN 1: Datos de la Empresa
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-building.me-2
                | 1. Datos de la Empresa
            .p-4
              .mb-3
                label.form-label.text-muted.small Nombre Comercial o Razón Social
                input.form-control.bg-light(type="text", name="empresa", placeholder="Ej: TechSupplies Inc.", required)
              
              .mb-3
                label.form-label.text-muted.small RFC Fiscal
                input.form-control.bg-light.text-uppercase(type="text", name="rfc", placeholder="Opcional pero recomendado", maxlength="13")

              .mb-3
                label.form-label.text-muted.small Categoría Principal
                select.form-select.bg-light(name="categoria")
                  option(value="" disabled selected) Seleccionar...
                  option(value="electronica") Electrónica de Consumo
                  option(value="perifericos") Periféricos / Accesorios
                  option(value="software") Mayorista de Software
                  option(value="oficina") Mobiliario de Oficina
                  option(value="otro") Otro rubro logístico

      //- SECCIÓN 2: Persona de Contacto
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-address-card.me-2
                | 2. Contacto Administrativo / Ventas

            .p-4
              .mb-3
                label.form-label.text-muted.small Nombre del Contacto
                input.form-control.bg-light(type="text", name="contacto", placeholder="Ej: Lic. Antonio Aguilar", required)

              .row.mb-3
                .col-md-6
                  label.form-label.text-muted.small Teléfono Celular / Oficina
                  input.form-control.bg-light(type="tel", name="telefono", placeholder="(555) 123-4567")
                .col-md-6
                  label.form-label.text-muted.small Extensión
                  input.form-control.bg-light(type="text", name="ext", placeholder="Ej: 104")

              .mb-3
                label.form-label.text-muted.small Correo Electrónico Comercial
                input.form-control.bg-light(type="email", name="email", placeholder="ventas@techsupplies.com", required)

    .row.mt-4
      .col-12.text-end
        button.btn.btn-primary-custom.px-5.py-2(type="submit")
          i.fa-solid.fa-truck-arrow-right.me-2
          | Confirmar Alta de Proveedor

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.querySelector('form');
      form.addEventListener('submit', function(e) {
        const empresa = form.querySelector('[name="empresa"]');
        const contacto = form.querySelector('[name="contacto"]');
        const email = form.querySelector('[name="email"]');
        const telefono = form.querySelector('[name="telefono"]');
        const rfc = form.querySelector('[name="rfc"]');
        let errors = [];

        if (!empresa.value.trim()) errors.push('La razón social es obligatoria');
        if (!contacto.value.trim()) errors.push('El nombre del contacto es obligatorio');

        if (!email.value.trim()) {
          errors.push('El correo electrónico es obligatorio');
        } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
          errors.push('El correo electrónico no tiene un formato válido');
        }

        if (telefono.value.trim()) {
          const digits = telefono.value.replace(/\D/g, '');
          if (digits.length < 7 || digits.length > 15) errors.push('El teléfono debe tener entre 7 y 15 dígitos');
        }

        if (rfc.value.trim() && !/^[A-ZÑ&]{3,4}\d{6}[A-Z0-9]{3}$/i.test(rfc.value.trim())) {
          errors.push('El RFC no tiene un formato válido (ej: XAXX010101000)');
        }

        if (errors.length > 0) {
          e.preventDefault();
          let existingAlert = document.querySelector('.validation-alert');
          if (existingAlert) existingAlert.remove();
          const alertDiv = document.createElement('div');
          alertDiv.className = 'validation-alert alert alert-danger';
          alertDiv.innerHTML = '<strong>Errores:</strong><ul>' + errors.map(er => '<li>' + er + '</li>').join('') + '</ul>';
          form.prepend(alertDiv);
          window.scrollTo({top: 0, behavior: 'smooth'});
        }
      });
    });

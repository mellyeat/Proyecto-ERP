extends ../layout/main.pug

block variables
  - var activePage = 'productos'
  - var title = 'Edición de Producto - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Modificar Producto

  .row
    .col-md-6.mx-auto
      .card-custom
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
              i.fa-solid.fa-pencil.me-2
              | Editar Producto
          .p-4
            form(action="/productos/edit", method="POST")
              input(type="hidden", name="id", value=producto.id)
              .mb-3
                label.form-label.text-muted.small Nombre del Producto
                input.form-control.bg-light(type="text", name="nombre", value=producto.nombre, required)
              .mb-3
                label.form-label.text-muted.small Proveedor
                select.form-select.bg-light(name="proveedor", required)
                  option(value="" disabled) Seleccionar un proveedor...
                  if proveedores && proveedores.length > 0
                    each prov in proveedores
                      option(value=prov.id, selected=(producto.proveedor_id == prov.id))= prov.razon_social
              .mb-3
                label.form-label.text-muted.small Stock Disponible
                input.form-control.bg-light(type="number", name="stock", value=producto.stock, required)
              .mb-3
                label.form-label.text-muted.small Precio Unitario ($)
                input.form-control.bg-light(type="number", step="0.01", name="precio", value=producto.precio, required)
              
              .d-flex.gap-3.mt-4
                a.btn.btn-secondary.w-50(href="/productos/consultas") Cancelar
                button.btn.btn-primary-custom.w-50(type="submit") Guardar Cambios

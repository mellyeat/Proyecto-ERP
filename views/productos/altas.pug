extends ../layout/main.pug

block variables
  - var activePage = 'productos'
  - var title = 'Alta de Productos - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Alta de Productos

  .row
    .col-md-6.mx-auto
      .card-custom
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
              i.fa-solid.fa-plus-circle.me-2
              | Agregar Producto
          .p-4
            form(action="/productos/add", method="POST")
              .mb-3
                label.form-label.text-muted.small Nombre del Producto
                input.form-control.bg-light(type="text", name="nombre", placeholder="Ej: Teclado Mecánico", required)
              .mb-3
                label.form-label.text-muted.small Proveedor
                select.form-select.bg-light(name="proveedor", required)
                  option(value="" disabled selected) Seleccionar un proveedor...
                  if proveedores && proveedores.length > 0
                    each prov in proveedores
                      option(value=prov.id)= prov.razon_social
              .mb-3
                label.form-label.text-muted.small Stock Disponible
                input.form-control.bg-light(type="number", name="stock", placeholder="Ej: 50", required)
              .mb-3
                label.form-label.text-muted.small Precio Unitario ($)
                input.form-control.bg-light(type="number", step="0.01", name="precio", placeholder="Ej: 25.50", required)
              button.btn.btn-primary-custom.w-100(type="submit") Añadir Producto

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.querySelector('form');
      form.addEventListener('submit', function(e) {
        const nombre = form.querySelector('[name="nombre"]');
        const proveedor = form.querySelector('[name="proveedor"]');
        const stock = form.querySelector('[name="stock"]');
        const precio = form.querySelector('[name="precio"]');
        let errors = [];

        if (!nombre.value.trim()) errors.push('El nombre del producto es obligatorio');
        if (!proveedor.value) errors.push('Debes seleccionar un proveedor');
        if (stock.value === '' || Number(stock.value) < 0 || !Number.isInteger(Number(stock.value))) errors.push('El stock debe ser un número entero mayor o igual a 0');
        if (precio.value === '' || Number(precio.value) <= 0) errors.push('El precio debe ser mayor a 0');

        if (errors.length > 0) {
          e.preventDefault();
          let existingAlert = document.querySelector('.validation-alert');
          if (existingAlert) existingAlert.remove();
          const alertDiv = document.createElement('div');
          alertDiv.className = 'validation-alert alert alert-danger';
          alertDiv.innerHTML = '<strong>Errores:</strong><ul>' + errors.map(er => '<li>' + er + '</li>').join('') + '</ul>';
          form.parentElement.prepend(alertDiv);
        }
      });
    });

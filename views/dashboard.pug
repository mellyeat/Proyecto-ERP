doctype html
html
  head
    title Dashboard ERP
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

  body.bg-light

    // Navbar
    nav.navbar.navbar-dark.bg-dark.shadow-sm
      .container-fluid
        span.navbar-brand.fw-bold Mini ERP
        a.btn.btn-outline-light(href="/") Cerrar sesión

    .container-fluid
      .row

        // barra lateral
        .col-md-2.bg-white.shadow-sm.min-vh-100.p-3
          h6.text-muted MENÚ
          ul.nav.flex-column.mt-3
            li.nav-item
              a.nav-link.active(href="/dashboard")
                i.bi.bi-speedometer2.me-2
                | Dashboard
            li.nav-item
              a.nav-link(href="/empleados")
                i.bi.bi-people.me-2
                | Empleados
            li.nav-item
              a.nav-link(href="/productos")
                i.bi.bi-box-seam.me-2
                | Productos
            li.nav-item
              a.nav-link(href="/ventas")
                i.bi.bi-cash-stack.me-2
                | Ventas

        // contenido
        .col-md-10.p-4

          h2.mb-4 Panel de Control

          // tarjetas prim
          .row.g-4

            .col-md-4
              .card.shadow.border-0
                .card-body
                  .d-flex.justify-content-between
                    div
                      h6.text-muted Empleados
                      h3.fw-bold #{empleados}
                    i.bi.bi-people-fill.fs-1.text-primary

            .col-md-4
              .card.shadow.border-0
                .card-body
                  .d-flex.justify-content-between
                    div
                      h6.text-muted Productos
                      h3.fw-bold #{productos}
                    i.bi.bi-box-seam.fs-1.text-success

            .col-md-4
              .card.shadow.border-0
                .card-body
                  .d-flex.justify-content-between
                    div
                      h6.text-muted Ventas Totales
                      h3.fw-bold $#{ventas}
                    i.bi.bi-cash-stack.fs-1.text-warning

          // Gráficos (Métricas)
          .row.mt-4
            .col-md-6
              .card.shadow.border-0
                .card-header.bg-white.fw-bold Ventas por Día (Últimos 7 días)
                .card-body
                  canvas#ventasChart(height="200")
            
            .col-md-6
              .card.shadow.border-0
                .card-header.bg-white.fw-bold Top 5 Productos Vendidos
                .card-body
                  canvas#productosChart(height="200")

          // tabla principal
          .card.shadow.border-0.mt-4
            .card-body
              h5.mb-3 Últimas Ventas
              table.table.table-hover
                thead.table-light
                  tr
                    th ID
                    th Cliente
                    th Producto
                    th Monto
                tbody
                  if listaVentas && listaVentas.length > 0
                    each venta in listaVentas
                      tr
                        td #{venta.id}
                        td #{venta.cliente}
                        td #{venta.producto}
                        td $#{venta.monto}
                  else
                    tr
                      td(colspan="4").text-center.text-muted No hay ventas registradas

    script(src="https://cdn.jsdelivr.net/npm/chart.js")
    script.
      document.addEventListener("DOMContentLoaded", async () => {
        try {
          const res = await fetch('/api/metricas');
          const data = await res.json();
          
          // Configurar gráfico de Ventas por Día (Líneas)
          const ctxVentas = document.getElementById('ventasChart').getContext('2d');
          new Chart(ctxVentas, {
            type: 'line',
            data: {
              labels: data.ventasPorDia.map(v => new Date(v.fecha).toLocaleDateString()),
              datasets: [{
                label: 'Ventas Diarias ($)',
                data: data.ventasPorDia.map(v => v.total),
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.2)',
                borderWidth: 2,
                fill: true,
                tension: 0.3
              }]
            },
            options: { responsive: true }
          });

          // Configurar gráfico de Top Productos (Dona)
          const ctxProductos = document.getElementById('productosChart').getContext('2d');
          new Chart(ctxProductos, {
            type: 'doughnut',
            data: {
              labels: data.topProductos.map(p => p.producto),
              datasets: [{
                label: 'Cantidad Vendida',
                data: data.topProductos.map(p => p.cantidad),
                backgroundColor: ['#198754', '#ffc107', '#dc3545', '#0dcaf0', '#6c757d']
              }]
            },
            options: { responsive: true }
          });

        } catch (error) {
          console.error("Error cargando métricas:", error);
        }
      });
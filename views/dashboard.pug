extends layout/main.pug

block variables
  - var activePage = 'dashboard'
  - var title = 'Dashboard ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Panel de Control
    span.text-muted Resumen General

  .row.g-4
    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Total Empleados
            h3.fw-bold.mb-0 #{empleados}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(9, 99, 126, 0.1);")
            i.fa-solid.fa-users.fs-3.metric-icon-empleados

    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Total Productos
            h3.fw-bold.mb-0 #{productos}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(8, 131, 149, 0.1);")
            i.fa-solid.fa-box-open.fs-3.metric-icon-productos

    .col-md-4
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Ventas Totales
            h3.fw-bold.mb-0 $#{ventas}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(122, 178, 178, 0.1);")
            i.fa-solid.fa-money-bill-wave.fs-3.metric-icon-ventas

  // Gráficos
  .row.mt-4.g-4
    .col-md-6
      .card-custom.h-100
        .card-body
          h6.fw-bold.mb-3(style="color: var(--color-dark-teal);") Ventas por Día (Últimos 7 días)
          .chart-wrapper.delay-1
            canvas#ventasChart(height="220" style="max-height: 250px;")
    
    .col-md-6
      .card-custom.h-100
        .card-body
          h6.fw-bold.mb-3(style="color: var(--color-dark-teal);") Top 5 Productos Vendidos
          .d-flex.justify-content-center
            .chart-wrapper.delay-2.w-100
              canvas#productosChart(height="220" style="max-height: 250px;")

  // tabla principal
  .card-custom.mt-4.mb-4
    .card-body.p-0
      .p-3.border-bottom
        h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") Últimas Ventas
      .table-responsive
        table.table.table-custom.mb-0
          thead
            tr
              th ID
              th Cliente
              th Producto
              th Monto
          tbody
            if listaVentas && listaVentas.length > 0
              each venta in listaVentas
                tr
                  td.text-muted ##{venta.id}
                  td #{venta.cliente}
                  td #{venta.producto}
                  td.fw-bold(style="color: var(--color-teal);") $#{venta.monto}
            else
              tr
                td(colspan="4").text-center.text-muted.p-4 No hay ventas registradas

block scripts
    script(src="https://cdn.jsdelivr.net/npm/chart.js")
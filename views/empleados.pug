extends layout/main.pug

block variables
  - var activePage = 'empleados'
  - var title = 'Empleados - ERP'

block content

  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Gestión de Empleados

  .row.g-4
    .col-md-4
      .card-custom
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
              i.fa-solid.fa-user-plus.me-2
              | Agregar Empleado
          .p-4
            form(action="/empleados/add", method="POST")
              .mb-3
                label.form-label.text-muted.small Nombre Completo
                input.form-control.bg-light(type="text", name="nombre_completo", placeholder="Ej: Juan Pérez", required)
              .row.mb-3
                .col-md-6
                  label.form-label.text-muted.small Usuario
                  input.form-control.bg-light(type="text", name="usuario", placeholder="Ej: jperez", required)
                .col-md-6
                  label.form-label.text-muted.small Contraseña
                  input.form-control.bg-light(type="password", name="password", placeholder="****", required)
              .row.mb-3
                .col-md-6
                  label.form-label.text-muted.small Puesto
                  input.form-control.bg-light(type="text", name="puesto", placeholder="Ej: Ventas")
                .col-md-6
                  label.form-label.text-muted.small Rol en Sistema
                  select.form-select.bg-light(name="rol", required)
                    option(value="SUPER ADMIN") SUPER ADMIN
                    option(value="RH") RH
                    option(value="VENTAS", selected) VENTAS
                    option(value="COMPRAS") COMPRAS
              .mb-3
                label.form-label.text-muted.small Salario Mensual ($)
                input.form-control.bg-light(type="number", step="0.01", name="salario", placeholder="Ej: 1500.00")
              button.btn.btn-primary-custom.w-100(type="submit") Añadir Empleado

    .col-md-8
      .card-custom.h-100
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-list.me-2
              | Lista de Empleados
          .table-responsive
            table.table.table-custom.mb-0
              thead
                tr
                  th ID
                  th Nombre Completo
                  th Credencial
                  th Puesto / Rol
                  th Salario
                  th Estado
              tbody
                if empleados && empleados.length > 0
                  each emp in empleados
                    tr
                      td.text-muted ##{emp.id}
                      td.fw-bold #{emp.nombre_completo}
                      td 
                        span.text-muted.small @#{emp.usuario}
                      td 
                        div.small #{emp.puesto}
                        span.badge.bg-secondary.rounded-pill(style="font-size: 0.70em;") #{emp.rol}
                      td.fw-bold(style="color: var(--color-teal);") $#{emp.salario}
                      td
                        if emp.activo
                          span.badge.bg-success Activo
                        else
                          span.badge.bg-danger Inactivo
                else
                  tr
                    td(colspan="6").text-center.text-muted.p-4 No hay empleados registrados

extends ../layout/main.pug

block variables
  - var activePage = 'clientes'
  - var title = 'Editar Cliente - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Editar Perfil de Cliente
    a.btn.btn-outline-secondary(href="/clientes/consultas")
      i.fa-solid.fa-arrow-left.me-2
      | Volver al Directorio

  form(action="/clientes/edit", method="POST")
    input(type="hidden", name="id", value=cliente.id)
    .row.g-4
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-address-book.me-2
                | 1. Datos de Contacto
            .p-4
              .mb-3
                label.form-label.text-muted.small Nombre Comercial o Etiqueta
                input.form-control.bg-light(type="text", name="nombre", value=cliente.nombre_comercial, required)
              
              .mb-3
                label.form-label.text-muted.small Nombre del Contacto Principal
                input.form-control.bg-light(type="text", name="contacto", value=cliente.contacto_principal)

              .row.mb-3
                .col-md-6
                  label.form-label.text-muted.small Teléfono
                  input.form-control.bg-light(type="tel", name="telefono", value=cliente.telefono)
                .col-md-6
                  label.form-label.text-muted.small Correo Electrónico
                  input.form-control.bg-light(type="email", name="email", value=cliente.email, required)

      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom.d-flex.justify-content-between.align-items-center
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-file-invoice-dollar.me-2
                | 2. Perfil de Facturación
              .form-check.form-switch
                input.form-check-input#requiereFactura(type="checkbox", name="requiere_factura", checked=(cliente.requiere_factura === 1 || cliente.requiere_factura === true))
                label.form-check-label.small.text-muted(for="requiereFactura") Req. Factura

            .p-4#seccionFacturacion
              .mb-3
                label.form-label.text-muted.small Razón Social / FACTURADO A:
                input.form-control.bg-light(type="text", name="razon_social", value=cliente.razon_social)

              .mb-3
                label.form-label.text-muted.small RFC
                input.form-control.bg-light.text-uppercase(type="text", name="rfc", value=cliente.rfc, maxlength="13")

              .mb-3
                label.form-label.text-muted.small Dirección Fiscal Completa
                textarea.form-control.bg-light(name="direccion", rows="2")= cliente.direccion_fiscal

              .row
                .col-md-6
                  label.form-label.text-muted.small Código Postal
                  input.form-control.bg-light(type="text", name="cp", value=cliente.codigo_postal, maxlength="5")
                .col-md-6
                  label.form-label.text-muted.small Régimen Fiscal
                  select.form-select.bg-light(name="regimen")
                    option(value="" disabled selected=(!cliente.regimen_fiscal)) Seleccionar...
                    option(value="601", selected=(cliente.regimen_fiscal == "601")) General de Ley Personas Morales
                    option(value="612", selected=(cliente.regimen_fiscal == "612")) Personas Físicas con Actividades...
                    option(value="626", selected=(cliente.regimen_fiscal == "626")) RESICO

    .row.mt-4
      .col-12.text-end
        button.btn.btn-warning.text-dark.px-5.py-2.fw-bold(type="submit")
          i.fa-solid.fa-pencil.me-2
          | Guardar Cambios

block scripts
  script.
    document.addEventListener("DOMContentLoaded", function() {
      const toggleFactura = document.getElementById('requiereFactura');
      const seccionFacturacion = document.getElementById('seccionFacturacion');
      
      toggleFactura.addEventListener('change', function() {
        if(this.checked) {
          seccionFacturacion.style.opacity = '1';
          seccionFacturacion.style.pointerEvents = 'auto';
        } else {
          seccionFacturacion.style.opacity = '0.3';
          seccionFacturacion.style.pointerEvents = 'none';
        }
      });
    });

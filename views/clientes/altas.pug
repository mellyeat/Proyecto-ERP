extends ../layout/main.pug

block variables
  - var activePage = 'clientes'
  - var title = 'Nuevo Cliente - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Registro de Nuevo Cliente
    a.btn.btn-outline-secondary(href="/clientes/consultas")
      i.fa-solid.fa-arrow-left.me-2
      | Volver al Directorio

  form(action="/clientes/add", method="POST")
    .row.g-4
      //- SECCIÃ“N 1: Datos de Contacto
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-address-book.me-2
                | 1. Datos de Contacto
            .p-4
              .mb-3
                label.form-label.text-muted.small Nombre Comercial o Etiqueta
                input.form-control.bg-light(type="text", name="nombre", placeholder="Ej: Empresa ACME", required)
              
              .mb-3
                label.form-label.text-muted.small Nombre del Contacto Principal
                input.form-control.bg-light(type="text", name="contacto", placeholder="Ej: Juan PÃ©rez")

              .row.mb-3
                .col-md-6
                  label.form-label.text-muted.small TelÃ©fono
                  input.form-control.bg-light(type="tel", name="telefono", placeholder="(123) 456-7890")
                .col-md-6
                  label.form-label.text-muted.small Correo ElectrÃ³nico
                  input.form-control.bg-light(type="email", name="email", placeholder="contacto@empresa.com", required)

      //- SECCIÃ“N 2: Datos de FacturaciÃ³n (Alineado con facturas.pug)
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom.d-flex.justify-content-between.align-items-center
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-file-invoice-dollar.me-2
                | 2. Perfil de FacturaciÃ³n
              .form-check.form-switch
                input.form-check-input#requiereFactura(type="checkbox", name="requiere_factura", checked)
                label.form-check-label.small.text-muted(for="requiereFactura") Req. Factura

            .p-4#seccionFacturacion
              .mb-3
                label.form-label.text-muted.small RazÃ³n Social / FACTURADO A:
                input.form-control.bg-light(type="text", name="razon_social", placeholder="Ej: Empresa ACME S.A.")

              .mb-3
                label.form-label.text-muted.small RFC
                input.form-control.bg-light.text-uppercase(type="text", name="rfc", placeholder="XAXX010101000", maxlength="13")

              .mb-3
                label.form-label.text-muted.small DirecciÃ³n Fiscal Completa
                textarea.form-control.bg-light(name="direccion", rows="2", placeholder="Av. Principal 456, Corporativo VIP, Ciudad")

              .row
                .col-md-6
                  label.form-label.text-muted.small CÃ³digo Postal
                  input.form-control.bg-light(type="text", name="cp", placeholder="12345", maxlength="5")
                .col-md-6
                  label.form-label.text-muted.small RÃ©gimen Fiscal
                  select.form-select.bg-light(name="regimen")
                    option(value="" disabled selected) Seleccionar...
                    option(value="601") General de Ley Personas Morales
                    option(value="612") Personas FÃ­sicas con Actividades...
                    option(value="626") RESICO

    .row.mt-4
      .col-12.text-end
        button.btn.btn-primary-custom.px-5.py-2(type="submit")
          i.fa-solid.fa-save.me-2
          | Guardar Cliente Completo

block scripts
  script.
    document.addEventListener("DOMContentLoaded", function() {
      const toggleFactura = document.getElementById('requiereFactura');
      const seccionFacturacion = document.getElementById('seccionFacturacion');
      
      toggleFactura.addEventListener('change', function() {
        if(this.checked) {
          seccionFacturacion.style.opacity = '1';
          seccionFacturacion.style.pointerEvents = 'auto';
        } else {
          seccionFacturacion.style.opacity = '0.3';
          seccionFacturacion.style.pointerEvents = 'none';
        }
      });

      // ValidaciÃ³n del formulario
      const form = document.querySelector('form');
      form.addEventListener('submit', function(e) {
        const nombre = form.querySelector('[name="nombre"]');
        const email = form.querySelector('[name="email"]');
        const telefono = form.querySelector('[name="telefono"]');
        const rfc = form.querySelector('[name="rfc"]');
        const cp = form.querySelector('[name="cp"]');
        let errors = [];

        if (!nombre.value.trim()) errors.push('El nombre comercial es obligatorio');

        if (!email.value.trim()) {
          errors.push('El correo electrÃ³nico es obligatorio');
        } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
          errors.push('El correo electrÃ³nico no tiene un formato vÃ¡lido');
        }

        if (telefono.value.trim()) {
          const digits = telefono.value.replace(/\D/g, '');
          if (digits.length < 7 || digits.length > 15) errors.push('El telÃ©fono debe tener entre 7 y 15 dÃ­gitos');
        }

        if (rfc.value.trim() && !/^[A-ZÃ‘&]{3,4}\d{6}[A-Z0-9]{3}$/i.test(rfc.value.trim())) {
          errors.push('El RFC no tiene un formato vÃ¡lido (ej: XAXX010101000)');
        }

        if (cp.value.trim() && !/^\d{5}$/.test(cp.value.trim())) {
          errors.push('El cÃ³digo postal debe ser de 5 dÃ­gitos');
        }

        if (errors.length > 0) {
          e.preventDefault();
          let existingAlert = document.querySelector('.validation-alert');
          if (existingAlert) existingAlert.remove();
          const alertDiv = document.createElement('div');
          alertDiv.className = 'validation-alert alert alert-danger';
          alertDiv.innerHTML = '<strong>Errores:</strong><ul>' + errors.map(er => '<li>' + er + '</li>').join('') + '</ul>';
          form.prepend(alertDiv);
          window.scrollTo({top: 0, behavior: 'smooth'});
        }
      });
    });

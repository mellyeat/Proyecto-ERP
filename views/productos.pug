doctype html
html
  head
    title Productos - ERP
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

  body.bg-light

    // Navbar
    nav.navbar.navbar-dark.bg-dark.shadow-sm
      .container-fluid
        span.navbar-brand.fw-bold Mini ERP
        a.btn.btn-outline-light(href="/") Cerrar sesión

    .container-fluid
      .row

        // barra lateral
        .col-md-2.bg-white.shadow-sm.min-vh-100.p-3
          h6.text-muted MENÚ
          ul.nav.flex-column.mt-3
            li.nav-item
              a.nav-link(href="/dashboard")
                i.bi.bi-speedometer2.me-2
                | Dashboard
            li.nav-item
              a.nav-link(href="/empleados")
                i.bi.bi-people.me-2
                | Empleados
            li.nav-item
              a.nav-link.active(href="/productos")
                i.bi.bi-box-seam.me-2
                | Productos
            li.nav-item
              a.nav-link(href="/ventas")
                i.bi.bi-cash-stack.me-2
                | Ventas

        .col-md-10.p-4

          h2.mb-4 Gestión de Productos

          .row
            .col-md-4
              .card.shadow.border-0
                .card-header.bg-white.fw-bold
                  | Agregar Producto
                .card-body
                  form(action="/productos/add", method="POST")
                    .mb-3
                      label.form-label Nombre del Producto
                      input.form-control(type="text", name="nombre", required)
                    .mb-3
                      label.form-label Stock
                      input.form-control(type="number", name="stock", required)
                    .mb-3
                      label.form-label Precio ($)
                      input.form-control(type="number", step="0.01", name="precio", required)
                    button.btn.btn-success.w-100(type="submit") Añadir

            .col-md-8
              .card.shadow.border-0
                .card-body
                  h5.mb-3 Inventario de Productos
                  table.table.table-hover
                    thead.table-light
                      tr
                        th ID
                        th Nombre
                        th Stock
                        th Precio
                    tbody
                      if productos && productos.length > 0
                        each prod in productos
                          tr
                            td #{prod.id}
                            td #{prod.nombre}
                            td(class=prod.stock < 10 ? 'text-danger fw-bold' : '') #{prod.stock}
                            td $#{prod.precio}
                      else
                        tr
                          td(colspan="4").text-center.text-muted No hay productos registrados

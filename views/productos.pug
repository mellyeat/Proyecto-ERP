extends layout/main.pug

block variables
  - var activePage = 'productos'
  - var title = 'Resumen de Productos - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Resumen del Inventario

  .row.g-4.mb-4
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Total Registros
            h3.fw-bold.mb-0 #{metrics ? metrics.total : 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(9, 99, 126, 0.1);")
            i.fa-solid.fa-box-open.fs-3(style="color: var(--color-dark-teal);")
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Unidades en Stock
            h3.fw-bold.mb-0 #{metrics ? metrics.stock_total : 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(25, 135, 84, 0.1);")
            i.fa-solid.fa-boxes-stacked.fs-3.text-success
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Próximos a Agotarse
            h3.fw-bold.mb-0 #{metrics ? metrics.bajo_stock : 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(255, 193, 7, 0.1);")
            i.fa-solid.fa-triangle-exclamation.fs-3.text-warning
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Sin Stock
            h3.fw-bold.mb-0 #{metrics ? metrics.sin_stock : 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(220, 53, 69, 0.1);")
            i.fa-solid.fa-circle-xmark.fs-3.text-danger

  //- Tabla y Gráfico
  .row.g-4
    .col-md-8
      .card-custom.h-100
        .card-body.p-0
          .p-3.border-bottom.d-flex.justify-content-between.align-items-center
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-arrow-trend-down.me-2
              | Productos con Bajo Stock
            a.btn.btn-sm.btn-outline-custom(href="/productos/consultas") Ver Inventario Completo
          .table-responsive
            table.table.table-custom.mb-0
              thead
                tr
                  th ID
                  th Producto
                  th Stock Actual
                  th Estado
                  th Acciones
              tbody
                if lowStockProducts && lowStockProducts.length > 0
                  each prod in lowStockProducts
                    tr
                      td.text-muted ##{prod.id}
                      td.fw-bold= prod.nombre
                      td= prod.stock
                      td
                        if prod.stock === 0
                          span.badge.bg-danger Agotado
                        else if prod.stock <= 3
                          span.badge.bg-danger Crítico
                        else if prod.stock <= 7
                          span.badge.bg-warning.text-dark Riesgo
                        else
                          span.badge.bg-info Bajo
                      td
                        .d-flex.gap-2
                          a.btn.btn-sm.btn-warning(href=`/productos/cambios?id=${prod.id}`, title="Editar")
                            i.fa-solid.fa-pencil
                          button.btn.btn-sm.btn-danger(title="Eliminar", onclick=`confirmarEliminarProd(${prod.id}, '${prod.nombre}')`)
                            i.fa-solid.fa-trash
                else
                  tr
                    td(colspan="5").text-center.text-muted.p-4 No hay productos con bajo stock

    .col-md-4
      .card-custom.h-100
        .card-body.p-0.d-flex.flex-column
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-chart-pie.me-2
              | Distribución de Inventario
          .p-4.flex-grow-1.d-flex.justify-content-center.align-items-center
            .chart-wrapper.w-100
              canvas#inventoryChart(style="max-height: 250px; width: 100%;")

  //- Modal: Confirmar Eliminación de Producto
  .modal.fade#modalEliminarProd(tabindex="-1", aria-labelledby="modalEliminarProdLabel", aria-hidden="true")
    .modal-dialog.modal-dialog-centered
      .modal-content(style="border: none; border-radius: 16px; overflow: hidden;")
        .modal-header.bg-danger.text-white(style="border: none;")
          h5.modal-title#modalEliminarProdLabel
            i.fa-solid.fa-triangle-exclamation.me-2
            | Eliminar Producto
          button.btn-close.btn-close-white(type="button", data-bs-dismiss="modal", aria-label="Cerrar")
        .modal-body.p-4
          p.mb-1 ¿Estás seguro de que deseas eliminar el producto:
          p.fw-bold.fs-5#nombreProdEliminar
          .alert.alert-warning.mt-3.mb-0
            i.fa-solid.fa-info-circle.me-2
            | Esta acción es irreversible. El historial de ventas conservará los registros existentes.
        .modal-footer(style="border-top: 1px solid #eee;")
          button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cancelar
          form#formEliminarProd(method="POST", style="margin: 0;")
            button.btn.btn-danger(type="submit")
              i.fa-solid.fa-trash.me-2
              | Sí, Eliminar

  //- Hidden data for chart
  script.
    window.__inventoryData = !{chartData};
block scripts
  script(src="https://cdn.jsdelivr.net/npm/chart.js")
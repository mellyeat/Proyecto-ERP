extends ../layout/main.pug

block variables
  - var activePage = 'empleados'
  - var title = 'Registrar Empleado - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Registrar Nuevo Empleado
    a.btn.btn-outline-secondary(href="/empleados/consultas")
      i.fa-solid.fa-arrow-left.me-2
      | Volver al Directorio

  form(action="/empleados/add", method="POST")
    .row.g-4
      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-user.me-2
                | 1. Datos Personales
            .p-4
              .mb-3
                label.form-label.text-muted.small Nombre Completo
                input.form-control.bg-light(type="text", name="nombre_completo", placeholder="Ej: Juan García López", required)
              .mb-3
                label.form-label.text-muted.small Puesto
                input.form-control.bg-light(type="text", name="puesto", placeholder="Ej: Vendedor, Contador, Gerente")
              .mb-3
                label.form-label.text-muted.small Salario Mensual ($)
                input.form-control.bg-light(type="number", step="0.01", name="salario", placeholder="Ej: 15000.00")

      .col-md-6
        .card-custom.h-100
          .card-body.p-0
            .p-3.border-bottom
              h6.fw-bold.mb-0(style="color: var(--color-dark-teal);")
                i.fa-solid.fa-key.me-2
                | 2. Acceso al Sistema
            .p-4
              .mb-3
                label.form-label.text-muted.small Usuario (Login)
                input.form-control.bg-light(type="text", name="usuario", placeholder="Ej: jgarcia", required)
              .mb-3
                label.form-label.text-muted.small Contraseña
                input.form-control.bg-light(type="password", name="password", placeholder="Mín. 6 caracteres", required)
              .mb-3
                label.form-label.text-muted.small Rol del Sistema
                select.form-select.bg-light(name="rol", required)
                  option(value="" disabled selected) Seleccionar rol...
                  option(value="admin") Administrador (Acceso Total)
                  option(value="RH") RH – Recursos Humanos
                  option(value="VENTAS") VENTAS – Módulo de Ventas
                  option(value="COMPRAS") COMPRAS – Módulo de Compras

    .row.mt-4
      .col-12.text-end
        button.btn.btn-primary-custom.px-5.py-2(type="submit")
          i.fa-solid.fa-save.me-2
          | Guardar Empleado

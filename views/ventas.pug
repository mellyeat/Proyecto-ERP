extends layout/main.pug

block variables
  - var activePage = 'ventas'
  - var title = 'Resumen de Ventas - ERP'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold(style="color: var(--color-dark-teal);") Resumen de Ventas

  //- Tarjetas de Métricas de Ventas
  .row.g-4.mb-4
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Ventas de Hoy
            h3.fw-bold.mb-0 #{metrics.ventas_hoy || 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(9, 99, 126, 0.1);")
            i.fa-solid.fa-cart-shopping.fs-3(style="color: var(--color-dark-teal);")
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Ingresos del Mes
            h3.fw-bold.mb-0 $#{metrics.ingresos_mes ? parseFloat(metrics.ingresos_mes).toLocaleString('es-MX') : '0'}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(25, 135, 84, 0.1);")
            i.fa-solid.fa-money-bill-trend-up.fs-3.text-success
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Ticket Promedio
            h3.fw-bold.mb-0 $#{metrics.ticket_promedio ? parseFloat(metrics.ticket_promedio).toFixed(0) : '0'}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(255, 193, 7, 0.1);")
            i.fa-solid.fa-receipt.fs-3.text-warning
          
    .col-md-3
      .card-custom.p-3
        .d-flex.justify-content-between.align-items-center
          div
            h6.text-muted.mb-1 Clientes Mensuales
            h3.fw-bold.mb-0 #{metrics.clientes_mes || 0}
          .icon-box.p-3.rounded-circle(style="background-color: rgba(13, 202, 240, 0.1);")
            i.fa-solid.fa-users.fs-3.text-info

  //- Gráficas y Resumen Adicional
  .row.g-4
    .col-md-8
      .card-custom.h-100
        .card-body.p-0.d-flex.flex-column
          .p-3.border-bottom.d-flex.justify-content-between.align-items-center
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-chart-line.me-2
              | Evolución de Ventas (Últimos 7 días)
          .p-4.flex-grow-1.d-flex.justify-content-center.align-items-center
            .chart-wrapper.w-100
              canvas#salesChart(style="max-height: 250px; width: 100%;")

    .col-md-4
      .card-custom.h-100
        .card-body.p-0
          .p-3.border-bottom
            h6.fw-bold.mb-0(style="color: var(--color-dark-teal);") 
              i.fa-solid.fa-star.me-2
              | Top Productos Vendidos
          .p-3
            ul.list-group.list-group-flush
              if topProducts && topProducts.length > 0
                each prod, i in topProducts
                  li.list-group-item.d-flex.justify-content-between.align-items-center.bg-transparent.px-0
                    span.text-muted #{i + 1}. #{prod.nombre}
                    - var colors = ['bg-success', 'bg-primary', 'bg-warning text-dark', 'bg-secondary', 'bg-info']
                    span(class=`badge ${colors[i] || 'bg-secondary'} rounded-pill`) #{prod.total_vendido} unds
              else
                li.list-group-item.bg-transparent.px-0.text-center.text-muted Sin datos de ventas

  //- Hidden data for chart
  script.
    window.__chartLabels = !{chartLabels};
    window.__chartValues = !{chartValues};
block scripts
  script(src="https://cdn.jsdelivr.net/npm/chart.js")